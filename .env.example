# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# --- Database (PostgreSQL) ---------------------------------------------
# Local dev via `docker compose up -d db` matches this default.
DATABASE_URL=postgresql://postgres:password@localhost:5432/ooo_agent?schema=public

# --- Auth (NextAuth v5 + Google OAuth) ----------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: restrict Google sign-in to a single Workspace domain (e.g. "example.com")
ALLOWED_DOMAIN=

# --- LLM (Gemini) --------------------------------------------------------
GEMINI_API_KEY=
# Optional: selects the provider implementation (defaults to gemini)
LLM_PROVIDER=gemini
# Optional: set to "mock" to force MockLLMProvider (useful for local dev/CI without an API key)
OVERRIDE_LLM=

# --- Vector store / embeddings --------------------------------------------
# Optional: set to "sqlite" to force the local Prisma-backed vector store instead of Supabase
OVERRIDE_VECTOR_STORE=
# Optional: URL of a remote embedding microservice (e.g. Cloud Run).
# If unset, falls back to the local @xenova/transformers model.
REMOTE_EMBEDDING_URL=

# --- Supabase (optional; used for vector store + service-role operations) -
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Cloud Tasks (Gmail webhook -> async processing queue) ---------
GOOGLE_CLOUD_PROJECT=
CLOUD_TASKS_QUEUE=email-processing-queue
CLOUD_TASKS_LOCATION=us-central1
# Pub/Sub topic for Gmail push notifications, e.g. projects/<project>/topics/<topic>
GMAIL_PUBSUB_TOPIC=

# --- Inngest (background jobs) --------------------------------------------
# "local" works with the Inngest dev server; use real keys in production.
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=local

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
